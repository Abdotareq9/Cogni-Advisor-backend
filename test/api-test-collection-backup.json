{
  "info": {
    "name": "Cogni-Advisor API Test Collection",
    "version": "1.0.0",
    "description": "مجموعة شاملة من جميع الـ API endpoints للاختبار - 64 endpoint مع أمثلة كاملة",
    "author": "Cogni-Advisor Team",
    "baseUrl": "http://localhost:5000"
  },
  "variables": {
    "BASE_URL": "http://localhost:5000",
    "ADMIN_TOKEN": "",
    "ADVISOR_TOKEN": "",
    "STUDENT_TOKEN": ""
  },
  "endpoints": [
    {
      "module": "Authentication",
      "description": "نقاط نهاية المصادقة وإدارة كلمات المرور",
      "requests": [
        {
          "name": "تسجيل الدخول - User Login",
          "method": "POST",
          "url": "{{BASE_URL}}/api/auth/login",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "identifier": "12345678901234",
            "password": "password123"
          },
          "description": "تسجيل دخول المستخدم باستخدام الرقم الوطني وكلمة المرور",
          "requiredRole": "public",
          "expectedResponse": {
            "status": 200,
            "body": {
              "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
              "user": {
                "id": 1,
                "role": "STUDENT",
                "first_name": "أحمد",
                "last_name": "محمد"
              }
            }
          }
        },
        {
          "name": "تغيير كلمة المرور - Change Password",
          "method": "PATCH",
          "url": "{{BASE_URL}}/api/auth/change-password",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{STUDENT_TOKEN}}"
          },
          "body": {
            "currentPassword": "password123",
            "newPassword": "newPassword456"
          },
          "description": "تغيير كلمة مرور المستخدم الحالي",
          "requiredRole": "any",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "Password updated successfully"
            }
          }
        }
      ]
    },
    {
      "module": "Users",
      "description": "إدارة المستخدمين (Admin فقط)",
      "requests": [
        {
          "name": "قائمة المستخدمين - List All Users",
          "method": "GET",
          "url": "{{BASE_URL}}/api/users",
          "headers": {
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "query": {
            "role": "STUDENT",
            "page": "1",
            "limit": "10"
          },
          "description": "الحصول على قائمة جميع المستخدمين مع إمكانية الفلترة",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "users": [],
              "total": 0,
              "page": 1
            }
          }
        },
        {
          "name": "إنشاء مستخدم جديد - Create User",
          "method": "POST",
          "url": "{{BASE_URL}}/api/users",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "body": {
            "first_name": "محمد",
            "middle_name": "أحمد",
            "last_name": "علي",
            "national_id": "30012250101234",
            "personal_email": "mohamed.ali@example.com",
            "password": "securePass123",
            "gender": "Male",
            "city_id": 1,
            "street_address": "123 شارع الجامعة، الجيزة",
            "role": "STUDENT"
          },
          "description": "إنشاء مستخدم جديد بأي دور (STUDENT, ADVISOR, ADMIN)",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 201,
            "body": {
              "id": 1,
              "first_name": "محمد",
              "last_name": "علي",
              "role": "STUDENT"
            }
          }
        },
        {
          "name": "تفاصيل مستخدم - Get User By ID",
          "method": "GET",
          "url": "{{BASE_URL}}/api/users/1",
          "headers": {
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "الحصول على تفاصيل مستخدم محدد",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "id": 1,
              "first_name": "محمد",
              "last_name": "علي",
              "personal_email": "mohamed.ali@example.com"
            }
          }
        },
        {
          "name": "تحديث مستخدم - Update User",
          "method": "PATCH",
          "url": "{{BASE_URL}}/api/users/1",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "body": {
            "first_name": "محمد المحدّث",
            "personal_email": "updated.email@example.com",
            "street_address": "عنوان جديد"
          },
          "description": "تحديث معلومات مستخدم موجود",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "User updated successfully"
            }
          }
        },
        {
          "name": "حذف مستخدم - Delete User",
          "method": "DELETE",
          "url": "{{BASE_URL}}/api/users/1",
          "headers": {
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "حذف مستخدم (حذف متتالي لجميع البيانات المرتبطة)",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "User deleted successfully"
            }
          }
        }
      ]
    },
    {
      "module": "Students",
      "description": "إدارة ملفات الطلاب والسجلات الأكاديمية",
      "requests": [
        {
          "name": "ملفي الشخصي - Get My Profile",
          "method": "GET",
          "url": "{{BASE_URL}}/api/students/me",
          "headers": {
            "Authorization": "Bearer {{STUDENT_TOKEN}}"
          },
          "description": "الحصول على ملف الطالب الشخصي",
          "requiredRole": "STUDENT",
          "expectedResponse": {
            "status": 200,
            "body": {
              "id": 1,
              "user_id": 1,
              "first_name": "أحمد",
              "last_name": "محمد",
              "national_id": "12345678901234",
              "university_email": "ahmed.mohamed@university.edu"
            }
          }
        },
        {
          "name": "ملخصي الأكاديمي - Get My Academic Summary",
          "method": "GET",
          "url": "{{BASE_URL}}/api/students/me/summary",
          "headers": {
            "Authorization": "Bearer {{STUDENT_TOKEN}}"
          },
          "description": "الحصول على الملخص الأكاديمي مع المعدل التراكمي GPA",
          "requiredRole": "STUDENT",
          "expectedResponse": {
            "status": 200,
            "body": {
              "student": {},
              "gpa": 3.5,
              "completedHours": 60,
              "remainingHours": 72
            }
          }
        },
        {
          "name": "تحديث ملفي - Update My Profile",
          "method": "PATCH",
          "url": "{{BASE_URL}}/api/students/me",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{STUDENT_TOKEN}}"
          },
          "body": {
            "first_name": "أحمد المحدّث",
            "last_name": "محمد",
            "street_address": "123 شارع النيل",
            "city_id": 2,
            "phones": ["+201234567890", "+201098765432"]
          },
          "description": "تحديث الملف الشخصي للطالب",
          "requiredRole": "STUDENT",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "Profile updated successfully"
            }
          }
        },
        {
          "name": "طالب محدد - Get Student By ID (Admin)",
          "method": "GET",
          "url": "{{BASE_URL}}/api/students/1",
          "headers": {
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "الحصول على تفاصيل طالب محدد (للإدارة)",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "id": 1,
              "user_id": 1,
              "cumulative_gpa": 3.5
            }
          }
        },
        {
          "name": "تحديث طالب - Update Student (Admin)",
          "method": "PUT",
          "url": "{{BASE_URL}}/api/students/1",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "body": {
            "cumulative_gpa": 3.7,
            "total_hours": 90,
            "current_level": 3
          },
          "description": "تحديث بيانات طالب (للإدارة)",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "Student updated successfully"
            }
          }
        },
        {
          "name": "تعطيل طالب - Deactivate Student (Admin)",
          "method": "PATCH",
          "url": "{{BASE_URL}}/api/students/1/deactivate",
          "headers": {
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "تعطيل حساب طالب (للإدارة)",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "Student deactivated successfully"
            }
          }
        }
      ]
    },
    {
      "module": "Courses",
      "description": "إدارة المقررات الدراسية والمتطلبات السابقة",
      "requests": [
        {
          "name": "قائمة المقررات - List All Courses",
          "method": "GET",
          "url": "{{BASE_URL}}/api/courses",
          "headers": {
            "Authorization": "Bearer {{STUDENT_TOKEN}}"
          },
          "query": {
            "is_available": "true",
            "search": "CS"
          },
          "description": "الحصول على قائمة جميع المقررات الدراسية",
          "requiredRole": "any",
          "expectedResponse": {
            "status": 200,
            "body": {
              "courses": []
            }
          }
        },
        {
          "name": "إنشاء مقرر - Create Course (Admin)",
          "method": "POST",
          "url": "{{BASE_URL}}/api/courses",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "body": {
            "course_code": "CS101",
            "course_name": "مقدمة في علوم الحاسب",
            "credits": 3,
            "required_hours_to_take": 0,
            "is_available": true
          },
          "description": "إنشاء مقرر دراسي جديد",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 201,
            "body": {
              "id": 1,
              "course_code": "CS101",
              "course_name": "مقدمة في علوم الحاسب"
            }
          }
        },
        {
          "name": "تفاصيل مقرر - Get Course By ID",
          "method": "GET",
          "url": "{{BASE_URL}}/api/courses/1",
          "headers": {
            "Authorization": "Bearer {{STUDENT_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "الحصول على تفاصيل مقرر محدد",
          "requiredRole": "any",
          "expectedResponse": {
            "status": 200,
            "body": {
              "id": 1,
              "course_code": "CS101",
              "course_name": "مقدمة في علوم الحاسب",
              "credits": 3
            }
          }
        },
        {
          "name": "تفاصيل مقرر مع المتطلبات - Get Course Details",
          "method": "GET",
          "url": "{{BASE_URL}}/api/courses/1/details",
          "headers": {
            "Authorization": "Bearer {{STUDENT_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "الحصول على مقرر مع المتطلبات السابقة",
          "requiredRole": "any",
          "expectedResponse": {
            "status": 200,
            "body": {
              "course": {},
              "prerequisites": []
            }
          }
        },
        {
          "name": "تحديث مقرر - Update Course (Admin)",
          "method": "PUT",
          "url": "{{BASE_URL}}/api/courses/1",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "body": {
            "course_name": "مقدمة محدثة في علوم الحاسب",
            "credits": 4,
            "required_hours_to_take": 30,
            "is_available": true
          },
          "description": "تحديث معلومات مقرر دراسي",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "Course updated successfully"
            }
          }
        },
        {
          "name": "حذف مقرر - Delete Course (Admin)",
          "method": "DELETE",
          "url": "{{BASE_URL}}/api/courses/1",
          "headers": {
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "حذف مقرر دراسي",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "message": "Course deleted successfully"
            }
          }
        },
        {
          "name": "تبديل إتاحة مقرر - Toggle Course Availability (Admin)",
          "method": "PATCH",
          "url": "{{BASE_URL}}/api/courses/1/toggle",
          "headers": {
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "params": {
            "id": "1"
          },
          "description": "تفعيل أو تعطيل مقرر دراسي",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 200,
            "body": {
              "success": true,
              "is_available": false
            }
          }
        },
        {
          "name": "إضافة متطلب سابق - Add Prerequisite (Admin)",
          "method": "POST",
          "url": "{{BASE_URL}}/api/courses/add-prerequisite",
          "headers": {
            "Content-Type": "application/json",
            "Authorization": "Bearer {{ADMIN_TOKEN}}"
          },
          "body": {
            "courseId": 2,
            "prerequisiteId": 1
          },
          "description": "إضافة متطلب سابق لمقرر دراسي",
          "requiredRole": "ADMIN",
          "expectedResponse": {
            "status": 201,
            "body": {
              "success": true,
              "message": "Prerequisite added successfully"
            }
          }
        }
      ]
    },
